<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Editar Cliente</title>

    <link rel="stylesheet" href="/style.css">
</head>
<body>

   <div class="sidebar">

    <div class="sidebar-logo">
        <h2>GestorPro</h2>
        <span>Sistema empresarial</span>
    </div>

    <div class="sidebar-menu">

        <a href="/dashboard">Dashboard</a>
        <a href="/clientes">Clientes</a>
        <a href="/ordens">Ordens</a>
        <a href="/financeiro">Financeiro</a>

        <% if(usuario.tipo === 'admin'){ %>
            <a href="/usuarios">Usuários</a>
        <% } %>

    </div>

    <div class="sidebar-user">
        <p><%= usuario.email %></p>
        <a href="/logout">Sair</a>
    </div>

</div>

</div>

    <div class="content">

        <h1>Editar Cliente</h1>

        <form class="form-box"
              action="/atualizar-cliente/<%= cliente.id %>"
              method="POST">

            <input
                type="text"
                name="nome"
                value="<%= cliente.nome %>"
            >

            <input
                type="text"
                name="telefone"
                value="<%= cliente.telefone %>"
            >

            <textarea
                name="observacoes"
            ><%= cliente.observacoes %></textarea>

            <button>
                Salvar Alterações
            </button>

        </form>

    </div>

</body>
</html>