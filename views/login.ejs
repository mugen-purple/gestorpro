<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Login</title>

    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <div class="login-box">

        <form action="/login" method="POST">

    <h1>Login</h1>

    <div class="input-group">

        <label>E-mail</label>

        <input
            type="email"
            name="email"
            placeholder="Digite seu e-mail"
        >

    </div>

    <div class="input-group">

        <label>Senha</label>

        <input
            type="password"
            name="senha"
            placeholder="Digite sua senha"
        >

    </div>

    <button>
        Entrar
    </button>
     <br><br>

     <a href="/registro">Criar conta</a>
</form>
    </div>

</body>
</html>